section.section.services#services
	.container
		h2.section-title Список дополнительных услуг
		include ../components/service-card.pug
		.services-grid
			.services-grid__main
				+service-card('resume', 'Резюме и профиль кандидата', [
					'Разбор готового резюме с рекомендациями',
					'Подготовка нового резюме или полная переработка текущего',
					'Дополнительная версия резюме под второе направление',
					'Оформление страницы кандидата в LinkedIn',
					'Адаптация резюме на английский язык'
				])
				+service-card('letters', 'Сопроводительные письма и отклики', [
					'Базовый шаблон сопроводительного письма',
					'Индивидуальное сопроводительное письмо под конкретную вакансию',
					'5 индивидуальных сопроводительных писем',
					'10 индивидуальных сопроводительных писем',
					'Проверка отклика перед отправкой'
				])
				+service-card('support', 'Поддержка во время поиска работы', [
					'Поддержка координатора в Telegram в течение 7 дней',
					'Поддержка координатора в Telegram в течение 14 дней',
					'Поддержка координатора в Telegram в течение 30 дней',
					'Еженедельный разбор результатов поиска',
					'Помощь с перепиской с работодателями в течение 7 дней'
				])
				+service-card('interviews', 'Подготовка к собеседованиям', [
					'Репетиция собеседования с обратной связью',
					'Подготовка к конкретному собеседованию',
					'Подготовка ко второму или финальному этапу',
					'Сравнение предложений о работе',
					'Подготовка к переговорам о заработной плате'
				])
				+service-card('portfolio', 'Портфолио', [
					'Разбор портфолио с рекомендациями',
					'Подготовка структуры и текстов для портфолио',
					'Визуальное оформление портфолио дизайнером'
				])
			.services-grid__aside
				+service-card('strategy', 'Стратегия поиска работы', [
					'Карьерная консультация: 60 минут',
					'Карьерная стратегия с письменным планом на 30 дней'
				])
				+service-card('vacancies', 'Подбор вакансий', [
					'Подборка из 20 подходящих вакансий',
					'Подборка из 40 подходящих вакансий',
					'Еженедельное обновление подборки: 15–20 новых вакансий'
				])
				+service-card('additional', 'Дополнительно', [
					'Срочная подготовка документов в течение 48 часов',
					'Работа сразу по двум направлениям',
					'Поиск работы на зарубежном рынке',
					'Поиск руководящей или редкой позиции'
				])
