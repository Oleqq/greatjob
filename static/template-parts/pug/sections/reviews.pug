section.section.reviews#reviews
	.container
		h2.section-title Отзывы о нашей работе

	include ../components/review-card.pug
	.reviews__slider.swiper(aria-label="Отзывы о нашей работе")
		.swiper-wrapper
			+review-card('Сегодня пришёл оффер от крупного Igaming холдинга', 'Я понимаю, я не самый обаятельный и приятный парень на свете, но чтоб никто... Именно так, я бы описал свою ситуацию до работы с командой. Сегодня пришёл оффер от крупного Igaming холдинга', 'Илья, Таргетолог', 'stars-5.svg')
			+review-card('В целом всё по делу', 'Резюме переписали, подготовился к вопросам — в целом всё по делу. Главное понял, что я нормально умею работать, но крайне плохо об этом рассказываю. Это оказалось важнее, чем я думал. Читайте больше классической литературы, друзья', 'Андрей, Middle Python-разработчик', 'stars-5-alt.svg', 'author-line-40.svg')
			+review-card('На днях получила оффер в большом агенстве', 'В моем старом портфолио было штук двадцать проектов вперемешку — лендинги, иконки, какой-то баннер для кофейни 2019 года, и конечно же карточки для ВБ. Выбрали пять нормальных, переписали описания по-человечески. Теперь не стыдно, когда отправляю ссылку. И кстати говоря, на днях получила оффер в большом агенстве, счастлива, как никогда', 'Елена, UX/UI-дизайнер', 'stars-5-alt2.svg')
			+review-card('Разложили с менеджером всё по полочкам', 'Смотрите, я провёл в продажах десять лет. Продавал дорогие курсы, недвижимость, и даже унитазы, а свой опыт так и не смог продать. Когда дошло до смены работы — не мог подчеркнуть свои сильные стороны на собесах. Разложили с менеджером всё по полочкам и пошло поехало', 'Артём, Head of Sales', 'stars-5-alt2.svg')
			+review-card('Кто-то, кто поможет подумать о твоей проблеме со стороны', 'Дали два оффера, маленький дедлайн, голова не варит. Сели, выписали всё на бумагу, сравнили нормально. Одна компания сразу отвалилась. Иногда просто нужен кто-то, кто поможет подумать о твоей проблеме со стороны, когда сам уже не можешь.', 'Дмитрий, Project Manager', 'stars-5-alt2.svg')
			+review-card('Помогли адаптировать резюме и объяснили, как лучше откликаться.', 'Мне нужно было выйти на Европу, но я не понимала, как оформить опыт на английском языке и что писать в LinkedIn. Помогли адаптировать резюме, заполнить страницу и объяснили, как лучше откликаться.', 'София, Копирайтер', 'stars-4.svg')

	.reviews__controls
		button.reviews__button.reviews__button--prev(type="button", aria-label="Предыдущий отзыв")
			img.reviews__button-icon(src="./images/reviews/arrow-left.svg", alt="", aria-hidden="true")
		button.reviews__button.reviews__button--next(type="button", aria-label="Следующий отзыв")
			img.reviews__button-icon(src="./images/reviews/arrow-right.svg", alt="", aria-hidden="true")
