section.section.pricing#pricing
	.container
		h2.section-title Тарифы
		include ../components/pricing-card.pug
		.pricing-grid
			+pricing-card('start', 'Лёгкий старт', '7 900 ₽', 'Экономия: 4 800 ₽', [
				'Карьерная консультация: 60 минут',
				'Одна услуга на выбор: полная переработка резюме или подготовка структуры и текстов для портфолио',
				'Базовый шаблон сопроводительного письма',
				'Добавление анкеты во внутреннюю базу кандидатов',
				'Поддержка в Telegram в течение 3 рабочих дней'
			])
			+pricing-card('preparation', 'Уверенная подготовка', '12 900 ₽', 'Экономия: 5 700 ₽', [
				'Карьерный трек с письменным планом на 30 дней',
				'Проведение репетиции собеседования',
				'Карьерная консультация: 60 минут',
				'Полная переработка резюме/портфолио под выбранную должность',
				'Шаблоны сопроводительного письма',
				'Добавление анкеты во внутреннюю базу кандидатов',
				'Поддержка в Telegram в течение 7 рабочих дней'
			], { label: 'Выгодно', modifier: 'deal' })
			+pricing-card('full', 'Полное сопровождение', '19 900 ₽', 'Экономия: 13 000 ₽', [
				'Откликаемся за вас',
				'Публикация в закрытой базе с 1000+ рекрутерами',
				'Дополнительный звонок с экспертом на 30 минут',
				'Подборка из 50 подходящих вакансий',
				'Карьерный трек с письменным планом на 30 дней',
				'Проведение репетиции собеседования',
				'Карьерная консультация: 60 минут',
				'Полная переработка резюме/портфолио под выбранную должность',
				'Шаблоны сопроводительного письма',
				'Добавление анкеты во внутреннюю базу кандидатов',
				'Поддержка в Telegram в течение 14 рабочих дней'
			], { label: 'Идеально', modifier: 'ideal' })
